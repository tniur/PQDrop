    "onboarding.step.local.storage.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encrypts files right on the device. Share containers without servers or clouds."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Шифрует файлы прямо на устройстве. Делитесь контейнерами без серверов и облаков."
          }
        }
      }
    },
    "onboarding.step.local.storage.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local Crypto Storage for Files"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Локальное крипто-хранилище для файлов"
          }
        }
      }
    },
    "onboarding.step.not.drm.mark" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "But intercepting a container does not mean the contents leaked."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Но перехват контейнера не означает утечку содержимого."
          }
        }
      }
    },
    "onboarding.step.not.drm.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If a recipient decrypts and saves a file, you can't take it back without servers or DRM mechanisms."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если получатель расшифровал и сохранил файл, забрать его назад нельзя без серверов или DRM-механизмов."
          }
        }
      }
    },
    "onboarding.step.not.drm.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important: This Is Not DRM"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Важно: это не DRM"
          }
        }
      }
    },
    "onboarding.step.offline.access.mark" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can share the key through a separate channel to reduce MITM risk."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ключ можно передать по другому каналу, чтобы снизить риск MITM."
          }
        }
      }
    },
    "onboarding.step.offline.access.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The container can be sent any way you like. The right to open it is shared separately through a QR code."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Контейнер отправляется любым способом. Право открыть передаётся отдельно через QR-код."
          }
        }
      }
    },
    "onboarding.step.offline.access.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Offline Sharing with Access Control"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оффлайн-обмен с контролем доступа"
          }
        }
      }
    },
    "onboarding.step.secure.container.mark" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encryption: AES-GCM and post-quantum access delegation"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Шифрование: AES-GCM и постквантовая выдача прав доступа"
          }
        }
      }
    },
    "onboarding.step.secure.container.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app encrypts the contents and stores them locally. Even if someone intercepts the container, it can't be opened without the key."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение шифрует содержимое и сохраняет его локально. Даже если контейнер перехватят, без ключа его не открыть."
          }
        }
      }
    },
    "onboarding.step.secure.container.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A File Becomes a Secure Container"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Файл превращается в защищённый контейнер"
          }
        }
      }
    },
    "onboarding.step.verify.keys.subtitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A public key can be replaced during exchange. Compare the fingerprint through an independent channel and mark the contact as verified."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Публичный ключ можно подменить при обмене. Сверьте fingerprint по независимому каналу и отметьте контакт как подтверждённый."
          }
        }
      }
    },
    "onboarding.step.verify.keys.title" : {
